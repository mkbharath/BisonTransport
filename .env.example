# =============================================================================
# Order Intelligence Platform — Environment Variables
# Copy to .env.local for local development
# =============================================================================

# --- Adapter Mode ---
ADAPTER_MODE=local  # local | aws

# --- Database ---
DATABASE_URL=postgresql+asyncpg://orderuser:orderpass@localhost:5432/orderdb
DATABASE_URL_SYNC=postgresql://orderuser:orderpass@localhost:5432/orderdb

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Queue (ElasticMQ for local, SQS for AWS) ---
QUEUE_ENDPOINT_URL=http://localhost:9324
QUEUE_REGION=us-east-1
QUEUE_ACCESS_KEY=local
QUEUE_SECRET_KEY=local

# --- Storage (MinIO for local, S3 for AWS) ---
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_ATTACHMENTS=attachments
STORAGE_BUCKET_EXTRACTED=extracted-text
STORAGE_BUCKET_EXPORTS=exports
STORAGE_REGION=us-east-1

# --- Email (MailHog for local, SES for AWS) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
EMAIL_FROM_ADDRESS=orders@orderplatform.local
EMAIL_REPLY_TO=orders@orderplatform.local

# --- LLM ---
LLM_PROVIDER=anthropic  # anthropic | bedrock | openai
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
LLM_MODEL_EXTRACTION=claude-sonnet-4-20250514
LLM_MODEL_CLASSIFICATION=claude-3-haiku-20240307
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

# --- OCR ---
OCR_PROVIDER=local  # local (pytesseract) | textract

# --- Email Intake ---
EMAIL_POLL_INTERVAL_SECONDS=60
EMAIL_INTAKE_MODE=file_watcher  # file_watcher | imap | msgraph
EMAIL_INBOX_DIR=./test-emails/inbox

# For IMAP mode:
# IMAP_HOST=imap.example.com
# IMAP_PORT=993
# IMAP_USERNAME=orders@example.com
# IMAP_PASSWORD=your-password

# For Microsoft Graph mode:
# MSGRAPH_TENANT_ID=your-tenant-id
# MSGRAPH_CLIENT_ID=your-client-id
# MSGRAPH_CLIENT_SECRET=your-client-secret
# MSGRAPH_MAILBOX=orders@example.com

# --- Auth (Local JWT) ---
JWT_SECRET_KEY=local-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Application ---
APP_NAME=Order Intelligence Platform
APP_VERSION=0.1.0
APP_ENV=local  # local | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# --- Confidence Thresholds (defaults; overridden by DB config) ---
THRESHOLD_AUTO_PROCESS=95
THRESHOLD_HUMAN_REVIEW=80
THRESHOLD_AUTO_COMMUNICATION=70
CUSTOMER_RESPONSE_TIMEOUT_HOURS=48
FOLLOWUP_DELAY_HOURS=24
DUPLICATE_DETECTION_WINDOW_HOURS=72
