FROM python:3.12-slim

WORKDIR /app

# Install system dependencies (including tesseract for OCR)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    tesseract-ocr \
    tesseract-ocr-eng \
    libgl1 \
    libglib2.0-0 \
    default-jre-headless \
    && rm -rf /var/lib/apt/lists/*

# Copy and install shared package first
COPY packages/shared/python /app/packages/shared/python
RUN pip install --no-cache-dir -e /app/packages/shared/python

# Copy and install agents package
COPY packages/agents /app/packages/agents
RUN pip install --no-cache-dir -e /app/packages/agents

# Copy test emails
COPY test-emails /app/test-emails

# Add src directories to Python path
ENV PYTHONPATH="/app/packages/agents/src:/app/packages/shared/python:${PYTHONPATH}"

CMD ["python", "-m", "order_agents.runner"]
