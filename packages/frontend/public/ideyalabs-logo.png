zero blocking */\n            @font-face{font-family:'Font Awesome 5 Free';font-style:normal;font-weight:900;font-display:optional;src:url('/fonts/fa-solid-900.woff2') format('woff2')}\n            @font-face{font-family:'Font Awesome 5 Brands';font-style:normal;font-weight:400;font-display:optional;src:url('/fonts/fa-brands-400.woff2') format('woff2')}\n            \n            /* Critical LCP optimizations - inlined for zero blocking */\n            *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n            html{font-family:var(--font-open-sans),system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;line-height:1.15;-webkit-text-size-adjust:100%;scroll-behavior:auto;scrollbar-gutter:stable;text-rendering:optimizeSpeed;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}\n            body{margin:0;font-family:var(--font-open-sans),system-ui,sans-serif;font-size:16px;line-height:1.5;color:#000;background:#fff;overflow-x:clip}\n            .font-loading{font-family:system-ui,sans-serif!important}\n            .fonts-loaded{font-family:var(--font-open-sans),system-ui,sans-serif!important}\n            \n            /* Split hero (agentic industry pages) — above-the-fold until async CSS loads */\n            [data-hero-variant=\"split\"]{position:relative;display:flex;flex-direction:column;color:#fff;background-color:#05080f;overflow:visible;padding:max(100px,calc(85px + 20px)) 0 clamp(40px,6vh,72px);min-height:0}\n            [data-hero-variant=\"split\"] [class*=\"heroLayout\"]{display:grid;grid-template-columns:1fr 1fr;gap:clamp(24px,4vw,48px);align-items:flex-start;width:100%;max-width:1240px;margin:0 auto;padding:0 20px}\n            [data-hero-variant=\"split\"] [class*=\"heroTitle\"]{font-family:var(--font-poppins,'Poppins',system-ui,sans-serif);font-size:44px;font-weight:700;line-height:1.16;color:#fff;margin:0 0 22px;text-shadow:0 2px 14px rgba(0,0,0,.55)}\n            [data-hero-variant=\"split\"] [class*=\"heroDescription\"]{font-family:var(--font-poppins,'Poppins',system-ui,sans-serif);font-size:16px;line-height:1.7;color:#fff;margin-bottom:22px;text-shadow:0 1px 10px rgba(0,0,0,.45)}\n            [data-hero-variant=\"split\"] [class*=\"heroButton\"] a,[data-hero-variant=\"split\"] [class*=\"heroButton\"] .btn{display:inline-block;padding:15px 30px;background:#e77625;color:#fff;text-decoration:none;border-radius:5px;font-weight:600}\n            @media (max-width:1199px){[data-hero-variant=\"split\"] [class*=\"heroLayout\"]{grid-template-columns:1fr}}\n            @media (max-width:767px){[data-hero-variant=\"split\"] [class*=\"heroTitle\"]{font-size:26px}[data-hero-variant=\"split\"] [class*=\"heroDescription\"]{font-size:14px}}\n            \n            /* Critical HeroSection styles for immediate LCP (full-height heroes only) */\n            [class*=\"HeroSection-module\"]:not([data-hero-variant=\"split\"]){position:relative;padding:1px 0;height:100vh;align-items:center;display:flex;overflow:hidden;background:linear-gradient(to right,rgba(17,17,17,0.8),rgba(51,51,51,0.8)),#111;contain:layout style paint;content-visibility:auto;contain-intrinsic-size:0 100vh;will-change:transform}\n            [class*=\"gradientBackground\"]{position:absolute;top:0;left:0;width:100%;height:100%;background:linear-gradient(to right,#111,#333);z-index:0;will-change:transform}\n            [class*=\"fullVideo\"]{position:absolute;right:0;bottom:0;width:100%;height:105%;object-fit:cover;object-position:center;opacity:0;z-index:1;transition:opacity 0.5s ease;will-change:opacity}\n            \n            header{position:relative;z-index:1000;contain:layout style}\n            .container{max-width:1200px;margin:0 auto;padding:0 15px}\n            img{max-width:100%;height:auto;vertical-align:middle;content-visibility:auto}\n            \n            /* Loading skeleton animation */\n            .loading-skeleton{animation:skeleton-loading 1.5s infinite ease-in-out;background:linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);background-size:200% 100%}\n            @keyframes skeleton-loading{0%{background-position:200% 0}100%{background-position:-200% 0}}\n            \n            /* Critical AboutSection styles for LCP optimization */\n            [class*=\"AboutSection-module\"]{background:#f5f5f5;position:relative;contain:layout style paint;content-visibility:auto;contain-intrinsic-size:0 500px;will-change:transform;isolation:isolate}\n            [class*=\"AboutSection-module\"] [class*=\"row\"]{display:flex;align-items:center;gap:60px}\n            [class*=\"AboutSection-module\"] [class*=\"textColumn\"]{flex:0 0 58.333%;max-width:58.333%}\n            [class*=\"AboutSection-module\"] [class*=\"textL\"] h2{font-size:40px;line-height:52px;font-weight:600;color:#050748;margin-bottom:20px;font-family:var(--font-poppins,'Poppins'),system-ui,sans-serif;text-rendering:optimizeLegibility;font-synthesis:weight style;letter-spacing:-0.02em}\n            [class*=\"AboutSection-module\"] [class*=\"subtitle\"]{font-size:22px!important;line-height:45px!important;font-weight:500!important;margin-bottom:30px!important}\n            [class*=\"AboutSection-module\"] [class*=\"mb20\"]{margin-bottom:20px;font-size:16px;line-height:28px;color:#6a6a8e;font-family:var(--font-open-sans,'Open Sans'),system-ui,sans-serif;text-rendering:optimizeLegibility;font-synthesis:weight style}\n            [class*=\"AboutSection-module\"] [class*=\"lcpText\"]{font-family:var(--font-open-sans,'Open Sans'),system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif!important;text-rendering:optimizeLegibility!important;-webkit-font-smoothing:antialiased!important;-moz-osx-font-smoothing:grayscale!important;font-synthesis:weight style!important;contain:layout style!important}\n            [class*=\"AboutSection-module\"] [class*=\"imageColumn\"]{flex:0 0 41.667%;max-width:41.667%}\n            [class*=\"AboutSection-module\"] [class*=\"singleImage\"]{position:relative